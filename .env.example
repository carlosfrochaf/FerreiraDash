# --- Desenvolvimento (padrão, sem Docker) ---
DATABASE_URL="file:./dev.db"

# --- Produção / Docker (PostgreSQL) ---
# Substitua provider em prisma/schema.prisma para "postgresql" e use:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ferreira_rocha?schema=public"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Docker / PostgreSQL local
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ferreira_rocha
